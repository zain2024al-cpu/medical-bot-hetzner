# ================================================
# إعدادات البوت الطبي - ملف مثال
# انسخ هذا الملف إلى config.env وقم بتعبئة القيم
# ================================================

# 🤖 توكن البوت من @BotFather
# احصل على التوكن من: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# 👑 معرفات الإداريين (ID Telegram)
# يمكنك الحصول على ID الخاص بك من: https://t.me/userinfobot
# ضع معرفات متعددة مفصولة بفاصلة
ADMIN_IDS=123456789,987654321

# 🌍 المنطقة الزمنية (الهند - IST UTC+5:30)
TIMEZONE=Asia/Kolkata

# 🗂️ مسار قاعدة البيانات (اختياري)
# سيتم إنشاؤه تلقائياً إذا لم يحدد
# DB_PATH=db/medical_reports.db

# 🧠 إعدادات الذكاء الاصطناعي
AI_ENABLED=true
AI_MODEL_NAME=gpt-4
AI_MAX_TOKENS=2000

# 🔑 OpenAI API Key (إذا أردت استخدام الذكاء الاصطناعي، ضع المفتاح هنا)
# احصل على المفتاح من: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# قاعدة البيانات (للاستضافة السحابية)
# DATABASE_URL سيتم إنشاؤه تلقائياً بواسطة Render/Heroku/Railway
DATABASE_URL=postgresql://user:password@host:port/database

# إعدادات إضافية للاستضافة
WEB_CONCURRENCY=1
PYTHONUNBUFFERED=1

# 🌐 إعدادات Hetzner VPS (للاستضافة أونلاين فقط)
# ضع true إذا كنت تشغّل على Hetzner VPS
HETZNER_DEPLOYMENT=false

# 🔌 Port (للاستضافة أونلاين - اتركه 0 للوضع المحلي)
PORT=0

# 🔗 Webhook URL (اختياري - اتركه فارغاً لاستخدام Polling)
WEBHOOK_URL=

# 🏥 إعدادات مجموعة التقارير - للأداء العالي تحت الضغط
# معرف المجموعة (مثل: -1001234567890)
# للحصول على معرف المجموعة:
# 1. أضف البوت للمجموعة كـ Admin
# 2. أرسل رسالة في المجموعة
# 3. اذهب إلى: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 4. ابحث عن "chat":{"id": -100xxxxxxxxx
# 5. انسخ الرقم السالب
REPORTS_GROUP_ID=

# تفعيل إرسال التقارير للمجموعة بدلاً من الإرسال الفردي
# true = إرسال للمجموعة فقط (موصى به للأداء العالي)
# false = إرسال فردي لكل مستخدم (الطريقة القديمة)
USE_GROUP_BROADCAST=true