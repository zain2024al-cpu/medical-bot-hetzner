# ================================================
# إعدادات البوت الطبي - ملف مثال
# انسخ هذا الملف إلى config.env وقم بتعبئة القيم
# ================================================

# 🤖 توكن البوت من @BotFather
# احصل على التوكن من: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# 👑 معرفات الإداريين (ID Telegram)
# يمكنك الحصول على ID الخاص بك من: https://t.me/userinfobot
# ضع معرفات متعددة مفصولة بفاصلة
ADMIN_IDS=123456789,987654321

# 📢 معرف مجموعة الإشعارات (لإشعارات طلبات المستخدمين)
# يمكنك إنشاء مجموعة وإضافة البوت إليها، ثم الحصول على ID المجموعة
# من @userinfobot أو من logs البوت عند إرسال رسالة للمجموعة
# مثال: NOTIFICATIONS_GROUP_ID=-1001234567890
NOTIFICATIONS_GROUP_ID=

# 🏥 معرف مجموعة توثيق الرعاية الصحية (تقارير الوحدات الصحية)
# مثال: HEALTHCARE_GROUP_ID=-1001234567890
HEALTHCARE_GROUP_ID=

# 🌍 المنطقة الزمنية
TIMEZONE=Asia/Riyadh

# 🗂️ مسار قاعدة البيانات (اختياري)
# سيتم إنشاؤه تلقائياً إذا لم يحدد
# DB_PATH=db/medical_reports.db

# 🧠 إعدادات الذكاء الاصطناعي
AI_ENABLED=true
AI_MODEL_NAME=gpt-4
AI_MAX_TOKENS=2000

# 🔑 OpenAI API Key (إذا أردت استخدام الذكاء الاصطناعي، ضع المفتاح هنا)
# احصل على المفتاح من: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# قاعدة البيانات (للاستضافة السحابية)
# DATABASE_URL سيتم إنشاؤه تلقائياً بواسطة Render/Heroku/Railway
DATABASE_URL=postgresql://user:password@host:port/database

# إعدادات إضافية للاستضافة
WEB_CONCURRENCY=1
PYTHONUNBUFFERED=1
